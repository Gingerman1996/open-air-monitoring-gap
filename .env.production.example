# Copy to .env.production on the host and fill in. The filled file is git-ignored.
#   cp .env.production.example .env.production   # then edit

# --- host wiring ---
# Sub-path this app is served under on tools.airgradient.net.
# The host's front reverse-proxy must PASS THIS PREFIX THROUGH (no URI rewrite),
# because the bundle's asset/router/API URLs are all built with it baked in.
APP_BASE_URL=/openair/
# Where the browser calls the API (same sub-path + /api/v1). Keep in sync with APP_BASE_URL.
NUXT_PUBLIC_API_BASE=/openair/api/v1
# Loopback port the host proxy forwards /openair/ to.
# Leave unset — deploy.sh scans the free slots (5300/5400/5500/5600), picks the first
# free one on the first deploy, and pins it back into this file so later deploys reuse it.
# WEB_PORT=5300

# --- secrets ---
# Postgres password — used by both the postgres container and the api DATABASE_URL.
POSTGRES_PASSWORD=change-me

# --- optional tuning (defaults shown; uncomment to override) ---
# INGEST_INTERVAL_MS=600000
# REFERENCE_CRON=0 0 1 * *
# REFERENCE_TZ=Asia/Bangkok
# AIRGRADIENT_MAP_API=https://map-data.airgradient.com/map/api/v1
# CORS_ORIGIN=*
