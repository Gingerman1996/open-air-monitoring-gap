# Copy to .env.int on the host and fill in. The filled file is git-ignored.
#   cp .env.int.example .env.int   # then edit

# --- host wiring ---
# Int sub-path (kept distinct from prod's /openair/ so both can run on one host).
# The host's front reverse-proxy must PASS THIS PREFIX THROUGH (no URI rewrite).
APP_BASE_URL=/openair-int/
NUXT_PUBLIC_API_BASE=/openair-int/api/v1
# Loopback port the host proxy forwards /openair-int/ to.
# Leave unset — deploy.sh auto-picks a free slot (skipping whatever prod already took) and pins it here.
# WEB_PORT=5400

# --- secrets ---
POSTGRES_PASSWORD=change-me
# Admin secret for runtime feature toggles (POST /api/v1/config/donations with header x-admin-token).
ADMIN_TOKEN=change-me
# Donation feature default when no runtime override is stored in Redis (true|false).
DONATIONS_ENABLED=true

# --- optional tuning (defaults shown; uncomment to override) ---
# INGEST_INTERVAL_MS=600000
# REFERENCE_CRON=0 0 1 * *
# REFERENCE_TZ=Asia/Bangkok
# AIRGRADIENT_MAP_API=https://map-data.airgradient.com/map/api/v1
# CORS_ORIGIN=*
