{
  "name": "@openair/api",
  "version": "0.1.0",
  "private": true,
  "description": "Open Air Monitoring Gap — NestJS API",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "seed": "ts-node -r tsconfig-paths/register src/seed/seed.ts",
    "ingest": "ts-node -r tsconfig-paths/register src/ingest/ingest.ts",
    "refresh-reference": "ts-node -r tsconfig-paths/register src/ingest/reference.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^8.0.1",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/topojson-client": "^3.1.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}
